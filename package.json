{
  "name": "@mitchallen/connection-grid-square",
  "version": "0.1.17",
  "description": "Connection grid for square grids",
  "main": "src/index.js",
  "browser": "dist/connection-grid-square.min.js",
  "scripts": {
    "start": "node src/index.js",
    "build": "node build.js",
    "lint": "eslint src/",
    "test": "node build.js && node --test $(find test -name '*-test.js' | sort)",
    "watch": "node build.js --watch",
    "test-square": "node --test $(find test/square -name '*-test.js')",
    "test-debug": "node --test $(find test -name '*-test.js' | sort)",
    "pubinit": "node build.js && npm publish --access public",
    "publish-pkg": "node build.js && npm version patch && git push --follow-tags && npm publish"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/mitchallen/connection-grid-square.git"
  },
  "author": "Mitch Allen <npm@mitchallen.com> (http://mitchallen.com)",
  "license": "MIT",
  "dependencies": {
    "@mitchallen/connection-grid-core": "^0.1.22",
    "@mitchallen/grid-square": "^0.1.9"
  },
  "devDependencies": {
    "esbuild": "^0.25.0",
    "eslint": "^9.0.0",
    "globals": "^16.0.0"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  }
}
